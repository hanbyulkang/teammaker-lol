# Riot Games API
# Get your key at: https://developer.riotgames.com/
# For production, apply for a Personal or Production API key
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Database (Neon Postgres recommended)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# App URL (used for metadata and sharing links)
NEXT_PUBLIC_APP_URL=https://teammaker.lol

# Optional: Contact email shown in footer / contact page
NEXT_PUBLIC_CONTACT_EMAIL=hello@teammaker.lol
